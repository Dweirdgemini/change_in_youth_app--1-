# Change In Youth - Environment Configuration
# Copy this file to .env and fill in your values for your environment
# REQUIRED variables must be set for the app to function

# ============================================================================
# AUTHENTICATION & OAUTH (REQUIRED)
# ============================================================================

# JWT secret for signing session tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# OAuth server URL (Manus platform)
OAUTH_SERVER_URL=https://oauth.manus.im

# Your app's ID from Manus platform
VITE_APP_ID=your-app-id-here

# Owner's OpenID (admin user)
OWNER_OPEN_ID=your-owner-openid

# ============================================================================
# DATABASE (REQUIRED)
# ============================================================================

# MySQL connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/change_in_youth

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Node environment
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# ============================================================================
# CORS & SECURITY (OPTIONAL)
# ============================================================================

# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# Custom domain for the app
CUSTOM_DOMAIN=https://changein.youth

# ============================================================================
# EMAIL SERVICE (OPTIONAL)
# ============================================================================

# Email service provider: console, sendgrid, or ses
EMAIL_SERVICE=console

# SendGrid API key (required if EMAIL_SERVICE=sendgrid)
SENDGRID_API_KEY=

# Email sender address
EMAIL_FROM=noreply@changeindelivery.org

# ============================================================================
# AWS CONFIGURATION (OPTIONAL)
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ============================================================================
# AGORA VIDEO CALLING (OPTIONAL)
# ============================================================================

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ============================================================================
# BUILT-IN LLM INTEGRATION (OPTIONAL)
# ============================================================================

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ============================================================================
# EXPO & WEB PREVIEW (DEVELOPMENT)
# ============================================================================

EXPO_WEB_PREVIEW_URL=http://localhost:8081
EXPO_PACKAGER_PROXY_URL=http://localhost:8081
