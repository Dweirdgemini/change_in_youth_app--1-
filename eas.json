{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://your-backend-production.railway.app"
      }
    },
    "preview2": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://your-backend-production.railway.app"
      }
    },
    "preview3": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://your-backend-production.railway.app"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://your-backend-production.railway.app",
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      }
    },
    "internal": {
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "disabled": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://your-backend-production.railway.app"
      }
    }
  }
}
