# Backend-only Environment Variables for Railway
NODE_ENV=production

# API Configuration (for mobile apps to connect)
EXPO_PUBLIC_API_BASE_URL=https://your-backend-production.railway.app

# App Configuration
VITE_APP_ID=your-app-id-here

# Database (Railway will provide this)
DATABASE_URL=${{RAILWAY_PRIVATE_DATABASE_URL}}

# Authentication
JWT_SECRET=${{RAILWAY_JWT_SECRET}}
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=your-owner-openid

# CORS - Allow mobile app origins
ALLOWED_ORIGINS=https://your-backend-production.railway.app,exp://*

# Email Service
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=${{SENDGRID_API_KEY}}
EMAIL_FROM=noreply@changeindelivery.org

# AWS (for SES email)
AWS_ACCESS_KEY_ID=${{AWS_ACCESS_KEY_ID}}
AWS_SECRET_ACCESS_KEY=${{AWS_SECRET_ACCESS_KEY}}

# Agora Video Calling
AGORA_APP_ID=${{AGORA_APP_ID}}
AGORA_APP_CERTIFICATE=${{AGORA_APP_CERTIFICATE}}

# Built-in Forge API
BUILT_IN_FORGE_API_URL=${{BUILT_IN_FORGE_API_URL}}
BUILT_IN_FORGE_API_KEY=${{BUILT_IN_FORGE_API_KEY}}

# Server Configuration
PORT=3000
