# Mobile App Environment Variables for Production Builds
NODE_ENV=production

# API Configuration - Point to Railway Backend
EXPO_PUBLIC_API_BASE_URL=https://your-backend-production.railway.app
EXPO_PUBLIC_API_URL=https://your-backend-production.railway.app

# OAuth Configuration
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://oauth.manus.im
EXPO_PUBLIC_OAUTH_SERVER_URL=https://oauth.manus.im
EXPO_PUBLIC_APP_ID=your-app-id-here
EXPO_PUBLIC_OWNER_OPEN_ID=your-owner-openid
EXPO_PUBLIC_OWNER_NAME=Your Organization Name

# App Configuration (matches backend)
EXPO_PUBLIC_CUSTOM_DOMAIN=changein.youth

# Build Configuration
EXPO_PUBLIC_ENVIRONMENT=production
